      <!-- 链接区 -->
      <div class="footer-links">
        <div class="link-group">
          <h4 class="link-title">文档</h4>
          <ul class="link-list">
            <li><a href="./guides/about/">关于</a></li>
            <li><a href="./guides/install/">安装指南</a></li>
            <li><a href="./guides/release_note/">更新日志</a></li>
            <li><a href="./guides/tck_report/">TCK 报告</a></li>
          </ul>
        </div>

        <div class="link-group">
          <h4 class="link-title">社区</h4>
          <ul class="link-list">
            <li><a href="https://github.com/smartboot/smart-servlet" target="_blank">GitHub</a></li>
            <li><a href="https://github.com/smartboot/smart-servlet/issues" target="_blank">问题反馈</a></li>
            <li><a href="https://github.com/smartboot/smart-servlet/discussions" target="_blank">讨论区</a></li>
            <li><a href="#">微信群</a></li>
          </ul>
        </div>

        <div class="link-group">
          <h4 class="link-title">生态</h4>
          <ul class="link-list">
            <li><a href="https://smartboot.tech/feat/" target="_blank">Feat 框架</a></li>
            <li><a href="https://smartboot.tech/smart-socket/" target="_blank">smart-socket</a></li>
            <li><a href="https://smartboot.tech/smart-mqtt/" target="_blank">smart-mqtt</a></li>
            <li><a href="https://smartboot.tech/redisun/" target="_blank">Redisun</a></li>
          </ul>
        </div>

        <div class="link-group">
          <h4 class="link-title">更多</h4>
          <ul class="link-list">
            <li><a href="./license/">开源协议</a></li>
            <li><a href="https://smartboot.tech/" target="_blank">官方网站</a></li>
            <li><a href="#">企业版</a></li>
          </ul>
        </div>
      </div>
    </div>

    <!-- 分割线 -->
    <div class="footer-divider"></div>

    <!-- 底部信息 -->
    <div class="footer-bottom">
      <div class="copyright">
        <p>&copy; {new Date().getFullYear()} smartboot. 保留所有权利。</p>
      </div>
      <div class="legal-links">
        <span>采用 <a href="./license/">AGPL-3.0</a> 开源协议</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .main-footer {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-color);
    padding: 4rem 1rem 2rem;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer-content {
    display: grid;
    grid-template-columns: 1.5fr 2fr;
    gap: 4rem;
    margin-bottom: 3rem;
  }

  @media (max-width: 768px) {
    .footer-content {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  /* 品牌区 */
  .footer-brand {
    max-width: 320px;
  }

  .brand-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    margin-bottom: 1rem;
  }

  .brand-logo {
    width: 36px;
    height: 36px;
  }

  .brand-name {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .brand-description {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin: 0 0 1.5rem;
  }

  .brand-links {
    display: flex;
    gap: 0.75rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 0.5rem;
    color: var(--text-secondary);
    transition: all 0.2s;
  }

  .social-link:hover {
    background: var(--accent-primary);
    border-color: var(--accent-primary);
    color: white;
    transform: translateY(-2px);
  }

  /* 链接区 */
  .footer-links {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  @media (max-width: 768px) {
    .footer-links {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .link-group {
    display: flex;
    flex-direction: column;
  }

  .link-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 1rem;
  }

  .link-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .link-list a {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: all 0.2s;
  }

  .link-list a:hover {
    color: var(--accent-primary);
  }

  /* 分割线 */
  .footer-divider {
    height: 1px;
    background: var(--border-color);
    margin-bottom: 2rem;
  }

  /* 底部 */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .copyright p {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin: 0;
  }

  .legal-links {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .legal-links a {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s;
  }

  .legal-links a:hover {
    color: var(--accent-primary);
  }

  @media (max-width: 768px) {
    .main-footer {
      padding: 3rem 1rem 1.5rem;
    }

    .footer-bottom {
      flex-direction: column;
      text-align: center;
    }
  }
</style>