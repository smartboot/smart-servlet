---

<footer class="main-footer">
  <div class="footer-container">
    <div class="footer-bottom">
      <div class="copyright">
        <p>&copy; {new Date().getFullYear()} smartboot. 保留所有权利。</p>
      </div>
      <div class="legal-links">
        <span>采用 <a href="./license/">AGPL-3.0</a> 开源协议</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .main-footer {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-color);
    padding: 1.5rem 1rem;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color);
  }

  .copyright p {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin: 0;
  }

  .legal-links {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .legal-links a {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s;
  }

  .legal-links a:hover {
    color: var(--accent-primary);
  }

  @media (max-width: 768px) {
    .footer-bottom {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
