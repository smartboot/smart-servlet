---
interface Props {
  companyName: string;
  creditCode: string;
  expireDate: string;
  licenseNo?: string;
}

const {
  companyName,
  creditCode,
  expireDate,
  licenseNo = "SSL-2026-0001",
} = Astro.props as Props;

const dialogId = `license-${creditCode}`;
---

<div class="license-card">
  <div class="license-info">
    <div class="license-company">
      🏅 {companyName}
    </div>

    <div class="license-code">
      统一社会信用代码：{creditCode}
    </div>
  </div>

  <button
    class="license-button"
    onclick={`document.getElementById('${dialogId}')?.showModal()`}
  >
    查看证书
  </button>
</div>

<dialog id={dialogId} class="certificate-dialog">
  <div class="certificate">
    <button
      class="close-button"
      onclick={`document.getElementById('${dialogId}')?.close()`}
    >
      ✕
    </button>

    <div class="certificate-header">
      <div class="badge">✓</div>

      <div>
        <div class="certificate-title">
          smart-servlet
        </div>

        <div class="certificate-subtitle">
          OFFICIAL LICENSE CERTIFICATE
        </div>
      </div>
    </div>

    <div class="certificate-content">
      <div class="certificate-label">
        授权企业
      </div>

      <div class="certificate-company">
        {companyName}
      </div>

      <div class="certificate-item">
        <span>统一社会信用代码</span>
        <strong>{creditCode}</strong>
      </div>

      <div class="certificate-item">
        <span>授权编号</span>
        <strong>{licenseNo}</strong>
      </div>

      <div class="certificate-item">
        <span>授权截止日期</span>
        <strong>{expireDate}</strong>
      </div>
    </div>

    <div class="certificate-footer">
      感谢贵司对 smart-servlet 项目的认可与支持
    </div>
  </div>
</dialog>

<style>
  .license-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;

    padding: 1.25rem 1.5rem;
    margin: 1rem 0;

    border: 1px solid var(--sl-color-gray-5);
    border-radius: 16px;

    background: var(--sl-color-bg);
  }

  .license-company {
    font-size: 1.1rem;
    font-weight: 700;
  }

  .license-code {
    margin-top: 0.5rem;

    color: var(--sl-color-gray-3);
    font-size: 0.9rem;
  }

  .license-button {
    cursor: pointer;

    border: none;
    border-radius: 10px;

    padding: 0.75rem 1rem;

    color: white;
    font-weight: 600;

    background: linear-gradient(
      135deg,
      #0ea5e9,
      #6366f1
    );
  }

  .certificate-dialog {
    max-width: 720px;
    width: calc(100vw - 2rem);

    padding: 0;
    border: none;
    border-radius: 24px;

    background: transparent;
  }

  .certificate-dialog::backdrop {
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
  }

  .certificate {
    position: relative;

    padding: 2rem;

    border-radius: 24px;

    background:
      linear-gradient(
        135deg,
        rgba(14, 165, 233, 0.08),
        rgba(99, 102, 241, 0.08)
      ),
      var(--sl-color-bg);

    border: 1px solid rgba(14, 165, 233, 0.2);
  }

  .close-button {
    position: absolute;

    top: 1rem;
    right: 1rem;

    border: none;
    background: transparent;

    cursor: pointer;

    font-size: 1.25rem;
  }

  .certificate-header {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .badge {
    display: flex;
    justify-content: center;
    align-items: center;

    width: 72px;
    height: 72px;

    border-radius: 50%;

    color: white;
    font-size: 2rem;
    font-weight: 700;

    background:
      linear-gradient(
        135deg,
        #0ea5e9,
        #6366f1
      );
  }

  .certificate-title {
    font-size: 1.8rem;
    font-weight: 800;
  }

  .certificate-subtitle {
    color: var(--sl-color-text-accent);

    letter-spacing: 0.15em;
    font-size: 0.85rem;
  }

  .certificate-content {
    margin-top: 2rem;
  }

  .certificate-label {
    color: var(--sl-color-text-accent);
  }

  .certificate-company {
    margin: 0.75rem 0 2rem;

    font-size: 2rem;
    font-weight: 700;
  }

  .certificate-item {
    display: flex;
    justify-content: space-between;

    margin-top: 1rem;
    padding-bottom: 0.75rem;

    border-bottom: 1px dashed
      var(--sl-color-gray-5);
  }

  .certificate-footer {
    margin-top: 2rem;

    color: var(--sl-color-gray-3);
    text-align: center;
  }

  @media (max-width: 640px) {
    .license-card {
      flex-direction: column;
      align-items: flex-start;
    }

    .license-button {
      width: 100%;
    }

    .certificate-company {
      font-size: 1.5rem;
    }

    .certificate-item {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>
